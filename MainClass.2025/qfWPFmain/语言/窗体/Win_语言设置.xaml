<Window x:Class="qfWPFmain.Win_语言设置"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:qfWPFmain"
        mc:Ignorable="d"
        Title="" Height="300" Width="600" WindowStyle="None" ResizeMode="NoResize" BorderThickness="1" BorderBrush="WhiteSmoke">

    <Grid>
        <Grid.RowDefinitions >
            <RowDefinition Height=" 40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--#region 标题栏-->
        <local:ui_window_Title Grid.Row="0" x:Name="_标题栏" ui_Text="{Binding Language_语言.语言}" ui_IsMaxButton="false" ui_IsMinButton="False" BorderBrush="Silver" BorderThickness="0,0,0,1"/>
        <!--#endregion-->


        <StackPanel Grid.Row="1">
            <StackPanel  Height="30" Margin="0,100,0,0">
                <ComboBox x:Name="_Combobox"  Height="30" Width="300"  FontSize=" 15" FontFamily=" 微软雅黑" 
                           ItemsSource="{Binding Items_语言包}"  SelectedIndex="{Binding Selectedindex}" SelectionChanged="_Combobox_SelectionChanged"  />
            </StackPanel>

            <StackPanel  Height=" 30">
                <!--提示-->
                <Label FontSize=" 15" FontFamily=" 微软雅黑" Content="{Binding Label_提示}" 
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                       VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                             Foreground="Silver"/>
            </StackPanel>

        </StackPanel>


    </Grid>
</Window>
