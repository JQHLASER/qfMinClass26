<Window x:Class="qfWPFmain.Win_设置_jczEzcad2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:qfWPFmain"
        mc:Ignorable="d"
        Title="" Height="500" Width="800" WindowStyle="None" >

    <Window.Resources >

        <ControlTemplate x:Key ="标签" TargetType="Label" >
            <Label Content="{TemplateBinding Content}" BorderThickness="0" 
                    Margin="0,0,10,0" Padding=" 0" 
                   Height="25" Width="200" FontSize="13" FontFamily="微软雅黑"  
                   Foreground="Gray"
                   HorizontalAlignment="Stretch"  HorizontalContentAlignment="Right" 
                   VerticalAlignment="Stretch"  VerticalContentAlignment="Center" />
        </ControlTemplate>



    </Window.Resources>




    <Grid>
        <Grid.RowDefinitions >
            <RowDefinition Height="40"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!--标题栏-->
        <local:ui_window_Title2 Grid.Row="0" x:Name="_标题栏" BorderThickness=" 0,0,0,2" BorderBrush="Silver"
                                ui_IsMaxButton="False"  ui_IsMinButton="False" />

        <!--IO设置-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--IN-->
            <GroupBox    Header="IN"   Grid.Column="0"
           Margin="10,5,0,10" FontSize="15" FontFamily="微软雅黑" Foreground="Gray">

                <StackPanel Orientation="Vertical"  VerticalAlignment="Center"  HorizontalAlignment="Left" >

                    <!--启动-->
                    <StackPanel  Orientation="Horizontal" Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}" Content="{Binding  Language_语言.启动_脚踏}"  
                               Name="_启动标刻" />
                        <local:ui_Combobox  ui_ItemsSource="{Binding Items_Port}" ui_SelectedIndex="{Binding Io_IN_启动标刻,Mode=TwoWay}" 
                                            Height=" 25" Width="80" />
                    </StackPanel>

                    <!--复位-->
                    <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}"  Content="{Binding  Language_语言.复位}" 
                               x:Name="_复位"/>
                        <local:ui_Combobox  ui_ItemsSource="{Binding Items_Port}" ui_SelectedIndex="{Binding Io_IN_复位,Mode=TwoWay}"
                                             Height=" 25" Width="80" />

                    </StackPanel>

                    <!--停止-->
                    <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}"  Content="{Binding  Language_语言.停止}" x:Name="_停止"/>
                        <local:ui_Combobox  ui_ItemsSource="{Binding Items_Port}" ui_SelectedIndex="{Binding Io_IN_停止,Mode=TwoWay}"
                                             Height=" 25" Width="80" />

                    </StackPanel>


                </StackPanel>

            </GroupBox>

            <!--OUT-->
            <GroupBox   Header="OUT"  Grid.Column="1"
            Margin="5,5,10,10" FontSize="15" FontFamily="微软雅黑" Foreground="Gray">

                <StackPanel Orientation="Vertical" VerticalAlignment="Center"  HorizontalAlignment="Left" >

                    <!--Ready准备好-->
                    <StackPanel  Orientation="Horizontal" Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}"  Content="Ready" x:Name="_软件准备好"/>
                        <local:ui_Combobox  ui_ItemsSource="{Binding Items_Port}" ui_SelectedIndex="{Binding Io_OUT_软件准备好,Mode=TwoWay}"
                                            Height=" 25" Width="80" />

                    </StackPanel>

                    <!--红光-->
                    <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}"  Content="{Binding  Language_语言.红光}"  
                               x:Name="_红光"/>
                        <local:ui_Combobox  ui_ItemsSource="{Binding Items_Port}" ui_SelectedIndex="{Binding Io_OUT_红光,Mode=TwoWay}"
                             Height=" 25" Width="80" />

                    </StackPanel>

                    <!--标刻中-->
                    <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}"  Content="{Binding  Language_语言.标刻中}"
                               x:Name="_标刻中"/>
                        <local:ui_Combobox  ui_ItemsSource="{Binding Items_Port}" ui_SelectedIndex="{Binding Io_OUT_标刻中,Mode=TwoWay}"
                             Height=" 25" Width="80" />

                    </StackPanel>

                    <!--标刻完成-->
                    <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}"  Content="{Binding  Language_语言.标刻完成}" 
                               x:Name="_标刻完成"/>
                        <local:ui_Combobox  ui_ItemsSource="{Binding Items_Port}" ui_SelectedIndex="{Binding Io_OUT_标刻完成,Mode=TwoWay}"
                                         Height=" 25" Width="80" />

                    </StackPanel>

                    <!--报警-->
                    <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}"  Content="{Binding  Language_语言.报警}" 
                               x:Name="_报警"/>
                        <local:ui_Combobox  ui_ItemsSource="{Binding Items_Port}" ui_SelectedIndex="{Binding Io_OUT_报警,Mode=TwoWay}"
                      Height=" 25" Width="80" />

                    </StackPanel>

                    <!--输出脉宽-->
                    <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                        <Label Template="{StaticResource 标签}"  Content="{Binding  Language_语言.输出脉宽}" x:Name="_输出脉宽"/>
                        <local:ui_TextBox Height="25" Width=" 80" 
                               ui_输入值类型="Int" ui_输入法是否启用="False" ui_TextInt="{Binding Io_OUT_输出脉宽,Mode=TwoWay}"/>
                    </StackPanel>



                </StackPanel>

            </GroupBox>


        </Grid>

        <!--其它设置-->
        <Grid  Grid.Row=" 2"   Margin="20,0,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--选择框-->
            <StackPanel    Orientation="Vertical" Grid.Column="0" >


                <!--进入时加载激光模板-->
                <local:ui_CheckBox x:Name="_进入时加载激光模板" 
                                   ui_Content ="{Binding  Language_语言.进入时加载激光模板}"                                    
                                       ui_IsChecked ="{Binding CheckBox_进入时加载激光模板,Mode=TwoWay}"/>

                <!--双击查看图像-->
                <local:ui_CheckBox x:Name="_双击查看图像" ui_Content ="{Binding  Language_语言.双击查看图像}" 
                        ui_IsChecked ="{Binding CheckBox_双击查看图像,Mode=TwoWay}"/>

                <!--红光指示轮廓-->
                <local:ui_CheckBox x:Name="_红光指示轮廓" ui_Content ="{Binding  Language_语言.红光指示轮廓}" 
           ui_IsChecked ="{Binding CheckBox_红光指示轮廓,Mode=TwoWay}"/>

                <!--加工时使能红光-->
                <local:ui_CheckBox x:Name="_加工时使能红光" ui_Content ="{Binding  Language_语言.加工时使能红光}" 
                                    ui_IsChecked ="{Binding CheckBox_加工时使能红光,Mode=TwoWay}"/>






            </StackPanel>


            <!--其它-->
            <StackPanel Orientation="Vertical" Grid.Column="1">


                <!--线程周期-->
                <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                    <Label Template="{StaticResource 标签}"  x:Name="_线程周期"  Content="{Binding  Language_语言.线程周期}"/>
                    <local:ui_TextBox Height="25" Width=" 160" 
                 ui_输入值类型="Int" ui_输入法是否启用="False" ui_TextInt="{Binding Ms_线程周期,Mode=TwoWay}"/>
                </StackPanel>


                <!--连续加工周期-->
                <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                    <Label Template="{StaticResource 标签}"  x:Name="_连续加工周期" Content="{Binding  Language_语言.连续加工周期}"/>
                    <local:ui_TextBox Height="25" Width=" 160" 
                                     ui_输入值类型="Int" ui_输入法是否启用="False" ui_TextInt="{Binding Ms_连续加工周期,Mode=TwoWay}"/>
                </StackPanel>


                <!--激光软件名称-->
                <StackPanel  Orientation="Horizontal"  Margin="0,5,0,0"  >
                    <Label Template="{StaticResource 标签}" x:Name="_激光软件名称"  Content="{Binding  Language_语言.激光软件名称}"/>
                    <local:ui_TextBox Height="25" Width=" 160" 
                                      ui_Text="{Binding Name_激光软件名称,Mode=TwoWay}"/>
                </StackPanel>

  

            </StackPanel>

        </Grid>







        <!--按钮栏-->
        <Border Grid.Row="3" BorderBrush="Silver" BorderThickness=" 0,2,0,0" >

            <StackPanel  Orientation="Horizontal" Margin="10"
                         VerticalAlignment="Center"  HorizontalAlignment="Center"  >
                <local:ui_ButtonBorder ui_Text="Yes" Width="150" Height="40" 
                                       PreviewMouseLeftButtonUp="ui_ButtonBorder_Yes_PreviewMouseLeftButtonUp"/>
                <Border Width="100"/>
                <local:ui_ButtonBorder ui_Text="No" Width="150" Height="40"
                                       PreviewMouseLeftButtonUp="ui_ButtonBorder_No_PreviewMouseLeftButtonUp" />
            </StackPanel>

        </Border>
    </Grid>

</Window>