<UserControl x:Class="qfWPFmain.ui_功能栏"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="800" Background="WhiteSmoke">

    <Border BorderThickness="0" Background="Transparent">
        <Grid>
            <Grid.ColumnDefinitions >
                <ColumnDefinition Width="*" x:Name="_Title_infoGrid"/>
                <ColumnDefinition Width="80" x:Name="_Title_icon_2Grid"/>
                <ColumnDefinition Width="80" x:Name="_Title_icon_1Grid"/>    
                <ColumnDefinition Width="80" x:Name="_Title_TimeGrid"/>
                <ColumnDefinition Width="100" x:Name="_Title_dateGrid"/>
                
            </Grid.ColumnDefinitions>

            <!--功能标题栏-->
            <TextBlock x:Name="_Title" Grid.Column="0" 
                       Text="AutoControl" VerticalAlignment="Center" FontFamily="微软雅黑" FontSize="17" Padding="10,0,0,0" 
                       Background="Transparent"  Foreground="Black"  
                       ></TextBlock>

            <!--商标图片1-->
            <Image x:Name="_icon2" Grid.Column="1" Stretch="Uniform" Margin="5"
                ></Image>

            <!--商标图片2-->
            <Image x:Name="_icon1" Grid.Column="2" Stretch="Uniform" Margin="5"
                ></Image>

            <!--软件运行时间...年月日-->     
                <TextBlock x:Name="_Times"    Grid.Column="3"  Margin="0"                                            
                FontSize="25"
                TextAlignment="Right"
                VerticalAlignment="Center"
                Background="Transparent"  
                 Foreground="Black" 
                Text="12:12"

               >
                </TextBlock>
          

            <!--软件运行时间...年月日-->           
                <TextBlock x:Name="_DateRun"       Grid.Column="4"  Margin="0"                                         
                           FontSize="13"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Background="Transparent"  
                            Foreground="Black" 
                           Text="000.00.00.00&#10;2025-08-08"

                          >
                </TextBlock>
                
             
            
            
        </Grid>
    </Border>
</UserControl>
