<Window x:Class="qfWPFmain.win_passwordBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:qfWPFmain"
        mc:Ignorable="d" 
        Height="300" Width="450" WindowStyle="None" 
        InputMethod.IsInputMethodEnabled="False"  >
    
    
    <Window.Resources>
        <SolidColorBrush x:Key="_color边框" Color="Silver"/>


    </Window.Resources>



    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!--#region  标题栏-->
         
            <local:ui_window_Title2 x:Name="_标题栏" Grid.Row="0"
                                   ui_IsCloseButton="True"  ui_IsMaxButton="false" ui_is启动时最大化显示="False" 
                                   ui_IsMinButton="False" ui_Text="PasswordBox"
                                   BorderThickness="0,0,0,2" BorderBrush="{StaticResource _color边框  }"
                ></local:ui_window_Title2>
       
        <!--#endregion-->

        <!--#region 密码输入框-->
        <local:ui_PasswordBox Grid.Row="1" x:Name="_passwordBox" Width="300" Height="40" ui_BorderThickness="2" ui_CornerRadius="20"
                              ></local:ui_PasswordBox>
        <!--#endregion-->

        <!--#region 按钮-->
        <Border Grid.Row="2" BorderBrush="{StaticResource _color边框}" BorderThickness="0,2,0,0" Padding="10">
            
                <local:ui_ButtonBorder  x:Name="_buttonOk" Grid.Column="1" ui_Text="OK"  Width=" 150" PreviewMouseLeftButtonUp="_buttonOk_PreviewMouseLeftButtonUp"/>            
            
        </Border>
        <!--#endregion-->

    </Grid>

</Window>
