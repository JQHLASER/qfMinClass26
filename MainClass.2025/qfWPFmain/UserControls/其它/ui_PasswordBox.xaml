<UserControl x:Class="qfWPFmain.ui_PasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="100" Loaded="UserControl_Loaded" InputMethod.IsInputMethodEnabled="False" >
    <Border Name="Border" 
             BorderThickness="1"
             CornerRadius="5"
             BorderBrush="Silver" 
             Background="White"  
             Padding="2"
             Margin="0"  
            >

        <PasswordBox Name="PasswordBox_"                       
                     FontFamily="微软雅黑"
                     FontSize="15"
                     Foreground="Gray"
                     Background="Transparent"
                     Padding=" 0"
                     Margin="0"
                
                     HorizontalAlignment="Stretch"
                     HorizontalContentAlignment="Center"
                     VerticalAlignment="Stretch" 
                     VerticalContentAlignment="Center"                  
                     
                     PasswordChar="*"
                     BorderBrush="Transparent"
                     InputMethod.IsInputMethodEnabled="False"
                     BorderThickness="0" KeyDown="PasswordBox_KeyDown"  
                     />

    </Border>
</UserControl>
