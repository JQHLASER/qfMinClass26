<UserControl x:Class="qfWPFmain.ui_IO"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain" 
             xmlns:qfwpfmain="clr-namespace:qfWPFmain"
             mc:Ignorable="d" 
             Background="White"  Padding="0" >

 
    <!--控件框-->
    <StackPanel   Orientation="Horizontal" Margin=" 0" >
        <qfwpfmain:ui_CheckBox  ui_IsChecked="False"  x:Name="_IO_0" ui_Content="0" Width="50" 
                                Event_PreviewMouseLeftButtonUp="CheckBox_0_PreviewMouseLeftButtonUp" />
        <qfwpfmain:ui_CheckBox  ui_IsChecked="False"  x:Name="_IO_1" ui_Content="1" Width="50"
                                Event_PreviewMouseLeftButtonUp="CheckBox_1_PreviewMouseLeftButtonUp"/>
        <qfwpfmain:ui_CheckBox  ui_IsChecked="False"  x:Name="_IO_2" ui_Content="2" Width="50"
                                Event_PreviewMouseLeftButtonUp="CheckBox_2_PreviewMouseLeftButtonUp"/>
        <qfwpfmain:ui_CheckBox  ui_IsChecked="False"  x:Name="_IO_3" ui_Content="3" Width="50"
                                Event_PreviewMouseLeftButtonUp="CheckBox_3_PreviewMouseLeftButtonUp"/>
        <qfwpfmain:ui_CheckBox  ui_IsChecked="False"  x:Name="_IO_4" ui_Content="4" Width="50"
                                Event_PreviewMouseLeftButtonUp="CheckBox_4_PreviewMouseLeftButtonUp"/>
        <qfwpfmain:ui_CheckBox  ui_IsChecked="False"  x:Name="_IO_5" ui_Content="5" Width="50"
                                Event_PreviewMouseLeftButtonUp="CheckBox_5_PreviewMouseLeftButtonUp"/>
        <qfwpfmain:ui_CheckBox  ui_IsChecked="False"  x:Name="_IO_6" ui_Content="6" Width="50"
                                Event_PreviewMouseLeftButtonUp="CheckBox_6_PreviewMouseLeftButtonUp"/>
        <qfwpfmain:ui_CheckBox  ui_IsChecked="False"  x:Name="_IO_7" ui_Content="7" Width="50"
                                Event_PreviewMouseLeftButtonUp="CheckBox_7_PreviewMouseLeftButtonUp"/>

    </StackPanel>




</UserControl>
