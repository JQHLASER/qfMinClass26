<UserControl x:Class="qfWPFmain.ui_TextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="100" Loaded="UserControl_Loaded" Background="Transparent"  >



    <Border Name="Border" VerticalAlignment="Stretch"  HorizontalAlignment="Stretch"  
           BorderThickness="1"
           CornerRadius="0"
           BorderBrush="Silver" 
           Background="White"               
           Padding="0"
           Margin="0"
          >

        <!--UpdateSourceTrigger=PropertyChanged //输入内容绑定到Text-->
        <!--Text="{Binding ui_Text,UpdateSourceTrigger=PropertyChanged , Mode=TwoWay }"-->
        <TextBox Name="TextBox_"
               
               Text="{Binding ui_Text,UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=local:ui_TextBox}, Mode=TwoWay}"
               FontFamily="微软雅黑"
               Width="auto" Height="auto"
               TextAlignment="Center"
               VerticalAlignment="Stretch"
               VerticalContentAlignment="Center" 
               HorizontalContentAlignment="Center" 
                 
               BorderThickness="0"
               IsReadOnly="False" 
               FontSize="14"
               Foreground="Black" 
               Background="Transparent" 
               BorderBrush="Transparent"
               TextWrapping="NoWrap"
               KeyDown="TextBox__KeyDown" 
               TextChanged="TextBox__TextChanged"
               AcceptsReturn="False"  
               PreviewTextInput="TextBox__PreviewTextInput"
          
               LostFocus="TextBox__LostFocus" 
          
          ></TextBox>

        <!--InputMethod.IsInputMethodEnabled="False"-->

    </Border>

    <!--Text="{Binding ui_Text,UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=local:ui_TextBox}, Mode=TwoWay}"-->


</UserControl>
