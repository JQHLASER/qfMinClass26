<UserControl x:Class="qfWPFmain.ui_CheckBoxTB"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d"  Background="White"   Padding ="2"     
             >

    <StackPanel Orientation="Vertical">
        <local:ui_Label2  ui_Content="232" x:Name="_标签_Top"/>
        <CheckBox VerticalAlignment="Center"   VerticalContentAlignment="Center" 
              HorizontalAlignment="Center"  HorizontalContentAlignment="Center" 
               Foreground="Gray"  BorderThickness="1.5"
              x:Name="_CheckBox" Checked="_CheckBox_Checked"
              PreviewMouseLeftButtonUp="_CheckBox_PreviewMouseLeftButtonUp" Unchecked="_CheckBox_Unchecked">


            <CheckBox.LayoutTransform>
                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
            </CheckBox.LayoutTransform>

        </CheckBox>
        <local:ui_Label2  ui_Content="CheckBox" x:Name="_标签_Bottom"/>
    </StackPanel>
</UserControl>
