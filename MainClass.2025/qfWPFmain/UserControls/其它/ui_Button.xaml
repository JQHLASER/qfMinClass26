<UserControl x:Class="qfWPFmain.ui_Button"              
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="120" Loaded="UserControl_Loaded" Background="Transparent">
    
    <Border  
         Name="Border"         
         CornerRadius="5" 
         BorderThickness="1"
         BorderBrush="#FFDDDBDA" 
         Background="Transparent" 
         Padding="0"
         Margin="0"  
      
        >
        
        <Button
            Name="Button"
            Content="Button"
            Background="WhiteSmoke"
            BorderBrush="Transparent"  
            FontFamily="微软雅黑" 
            FontSize="14"              
            Margin="0" Padding="0"
            BorderThickness="0" 
            Foreground="Black" 
            Width="auto" Height="auto"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch"
            
            Click="Button_Click"
            PreviewMouseLeftButtonDown="Button_PreviewMouseLeftButtonDown" 
            PreviewMouseLeftButtonUp="Button_PreviewMouseLeftButtonUp" 
            PreviewMouseDown="Button_PreviewMouseDown" 
            PreviewMouseUp="Button_PreviewMouseUp"  
           
            >
      
        </Button>
       
    </Border>
    
</UserControl>
