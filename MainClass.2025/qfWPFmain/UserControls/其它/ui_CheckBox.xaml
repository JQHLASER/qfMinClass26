<UserControl x:Class="qfWPFmain.ui_CheckBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d"  Background="White"    Padding="2"    
             >

    <CheckBox VerticalAlignment="Stretch"  VerticalContentAlignment="Center" 
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
              FontFamily="微软雅黑"  FontSize="12" Margin="0.5,0,0.5,0"              
              Content="CheckBox"  Foreground="Gray"  BorderThickness="1.5"
              x:Name="_CheckBox" Checked="_CheckBox_Checked"
              PreviewMouseLeftButtonUp="_CheckBox_PreviewMouseLeftButtonUp" Unchecked="_CheckBox_Unchecked">

        <CheckBox.LayoutTransform>
            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
        </CheckBox.LayoutTransform>

    </CheckBox>
</UserControl>
