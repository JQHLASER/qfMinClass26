<UserControl x:Class="qfWPFmain.ui_window_Title"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800" Loaded="UserControl_Loaded"  Background="WhiteSmoke"   >



    <Grid Background="{Binding Background_grid,Mode=OneWay}"  Margin="0">
        <Grid.ColumnDefinitions >
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="40" x:Name="_MinGrid"/>
            <ColumnDefinition Width="40" x:Name="_MaxGrid"/>
            <ColumnDefinition Width="40" x:Name="_CloseGrid"/>
        </Grid.ColumnDefinitions>


        <!--#region  最小化-->

        <Border     Grid.Column="1" Margin="1" BorderThickness="0" x:Name="_Min"  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    BorderBrush="Gray" 
                    MouseEnter="_Min_MouseEnter"  
                    MouseLeave="_Min_MouseLeave"
                    PreviewMouseLeftButtonUp="_Min_PreviewMouseLeftButtonUp" >
            <Border.Background>
                <ImageBrush ImageSource="/qfWPFmain;component/UserControls/Window 标题栏/Images/最小化.png" Stretch="Uniform" />
            </Border.Background>

        </Border>

        <!--#endregion-->


        <!--#region 最大化-->

        <Border Grid.Column="2" Margin="1" BorderThickness="0" x:Name="_Max"   VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                BorderBrush="Gray"
                MouseEnter="_Max_MouseEnter" 
                MouseLeave="_Max_MouseLeave" PreviewMouseLeftButtonUp="_Max_PreviewMouseLeftButtonUp"  >
            <Border.Background>
                <ImageBrush ImageSource="/qfWPFmain;component/UserControls/Window 标题栏/Images/最大化.png" Stretch="Uniform"/>
            </Border.Background>
        </Border>

        <!--#endregion-->


        <!--#region  关闭-->

        <Border Grid.Column="3" Margin="1" BorderThickness="0" x:Name="_Close"  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                BorderBrush="Gray" 
                MouseEnter="_Close_MouseEnter"  
                MouseLeave="_Close_MouseLeave" PreviewMouseLeftButtonUp="_Close_PreviewMouseLeftButtonUp" >
            <Border.Background>
                <ImageBrush ImageSource="/qfWPFmain;component/UserControls/Window 标题栏/Images/关闭.png" Stretch="Uniform"/>
            </Border.Background>
        </Border>

        <!--#endregion-->


        <!--#region 标题栏-->

        <TextBlock   Grid.Column="0" x:Name="_标题栏_TextBlock" Margin="0"
                 Text="{Binding Title}"  
                 Padding="0"
                 Foreground="Black"  
                 Background="Transparent"  
                 HorizontalAlignment="Stretch"
                 TextAlignment="Center"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap"
                 FontFamily="微软雅黑"
                 FontSize="14"
                 PreviewMouseLeftButtonDown="标题栏_PreviewMouseLeftButtonDown" 
                 
                 
                 ></TextBlock>

        <!--#endregion-->

    </Grid>


</UserControl>
