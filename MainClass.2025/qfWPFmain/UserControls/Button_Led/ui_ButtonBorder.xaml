<UserControl x:Class="qfWPFmain.ui_ButtonBorder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="100" Background="Transparent" >
    <Border x:Name="_button_border" Background="WhiteSmoke"  
            BorderBrush="Silver" BorderThickness="1" CornerRadius="5" 
            MouseEnter="_button_border_MouseEnter" 
            MouseLeave="_button_border_MouseLeave"
            PreviewMouseDown="_button_border_PreviewMouseDown" PreviewMouseUp="_button_border_PreviewMouseUp" 
            PreviewMouseLeftButtonDown="_button_border_PreviewMouseLeftButtonDown" 
            PreviewMouseLeftButtonUp="_button_border_PreviewMouseLeftButtonUp">
        
        
        <TextBlock  x:Name="_textblock" Text="Button" Background="Transparent" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Stretch" FontSize="14" FontFamily="微软雅黑"
                    
                    
                    ></TextBlock>
        
    </Border>
    
</UserControl>
