<Window x:Class="qfWPFmain.win_MessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:qfWPFmain"        
        Title="" Height="300" Width="500" MinHeight="300" MinWidth="450" WindowStyle="None" WindowState="Normal" KeyDown="Window_KeyDown"   
        InputMethod.IsInputMethodEnabled="False">

    <Window.Resources>
        <SolidColorBrush x:Key="_color边框" Color="Silver"/>


    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!--#region 标题栏-->

        <local:ui_window_Title2  Grid.Row="0"
                                    x:Name="_标题栏"
                                    ui_IsMinButton="False" 
                                    ui_is启动时最大化显示="False" 
                                    ui_IsCloseButton="False" 
                                    BorderThickness="0,0,0,2"
                                    BorderBrush="{StaticResource _color边框}"
            ></local:ui_window_Title2>

        <!--#endregion-->


        <!--#region 消息-->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"  Margin="5">
            <TextBlock     x:Name="_消息框"
                           TextWrapping="Wrap"  Padding="5"
                           TextAlignment="Left" VerticalAlignment="Center" HorizontalAlignment="Center" 
                           FontSize="18" FontFamily="宋体"
                           Text="Messagebox"   
            >
            </TextBlock>
        </ScrollViewer>
        <!--#endregion-->


        <!--#region  按钮-->
        <Border Grid.Row="2"     BorderThickness="0,2,0,0" BorderBrush="{StaticResource _color边框}">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                        VerticalAlignment="Stretch" 
                         Margin="0,10,0,10" >
                
                <local:ui_ButtonBorder  Grid.Column="1" x:Name="_Button_Yes" Width="120"
                     ui_Text="Yes"  Margin="10,0,10,0"  
                        PreviewMouseLeftButtonUp="_Button_Yes_PreviewMouseLeftButtonUp" 
                 >
                </local:ui_ButtonBorder>
                <local:ui_ButtonBorder Grid.Column="2" x:Name="_Button_Ok" Width="120"
                        ui_Text="OK"   Margin="10,0,10,0"  
                          PreviewMouseLeftButtonUp="_Button_Ok_PreviewMouseLeftButtonUp"
          >
                </local:ui_ButtonBorder>
                <local:ui_ButtonBorder Grid.Column="3" x:Name="_Button_No" Width="120"
                        ui_Text="No"  Margin="10,0,10,0" 
                          PreviewMouseLeftButtonUp="_Button_No_PreviewMouseLeftButtonUp"
          >
                </local:ui_ButtonBorder>

            </StackPanel>


        </Border>
        <!--#endregion-->

    </Grid>
</Window>
