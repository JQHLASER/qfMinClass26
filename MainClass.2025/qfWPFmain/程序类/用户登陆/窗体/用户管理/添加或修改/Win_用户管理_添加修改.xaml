<Window x:Class="qfWPFmain.Win_用户管理_添加修改"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:qfWPFmain"
        mc:Ignorable="d"
         Height="450" Width="600" WindowStyle="None" >
    <Grid>
        <Grid.RowDefinitions >
            <RowDefinition  Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 标题栏-->
        <local:ui_window_Title2 Grid.Row="0" x:Name="_标题栏"    ui_IsMinButton="False"  InputMethod.IsInputMethodEnabled="False" />

        <!-- 信息栏-->
        <StackPanel Orientation="Vertical" Grid.Row="1" Margin="0,10,30,0" VerticalAlignment="Center" >

            <StackPanel Orientation="Horizontal"  VerticalAlignment="Stretch" HorizontalAlignment="Center" 
                        Margin="10">
                <local:ui_Label2 ui_Content="用户" Width="100" ui_HorizontalContentAlignment="Right" Margin="0,0,10,0"/>
                <local:ui_TextBox   Width="250" Height ="30" ui_Text="{Binding Info_当前信息.UserName,Mode=TwoWay}"
                                    IsEnabled="{Binding IsEnable_用户}"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal"  VerticalAlignment="Stretch" HorizontalAlignment="Center"  
                        Margin=" 10">
                <local:ui_Label2 ui_Content="密码" Width="100" ui_HorizontalContentAlignment="Right" Margin="0,0,10,0"/>
                <local:ui_TextBox    Width="250" Height ="30" ui_Text="{Binding Info_当前信息.Passwrord,Mode=TwoWay }"
                                     IsEnabled="{Binding IsEnable_密码}"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal"  VerticalAlignment="Stretch" HorizontalAlignment="Center"
                        Margin=" 10">
                <local:ui_Label2 ui_Content="权限" Width="100" ui_HorizontalContentAlignment="Right" Margin="0,0,10,0"/>
                <local:ui_Combobox    Width="250" Height ="30" ui_SelectedIndex="{Binding SelectedIndex,Mode=TwoWay}"
                                      IsEnabled="{Binding IsEnable_权限}" ui_ItemsSource="{Binding Info_权限}"/>

            </StackPanel>

        </StackPanel>

        <!-- 按钮栏-->
        <Border x:Name="_border按钮栏" Grid.Row="2">
            <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" VerticalAlignment="Stretch"   >
                <local:ui_ButtonBorder  Width="150"  Margin="10" ui_Text="Yes" Command="{Binding saveCommand}"/>
                <local:ui_ButtonBorder  Width="150"  Margin="10" ui_Text="No"  Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
