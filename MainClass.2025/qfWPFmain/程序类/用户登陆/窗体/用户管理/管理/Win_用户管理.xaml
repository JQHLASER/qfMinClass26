<Window x:Class="qfWPFmain.Win_用户管理"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:qfWPFmain"
        mc:Ignorable="d"
        Height="450" Width="600" WindowStyle="None" >
    <Grid>

        <Grid.RowDefinitions >
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--标题栏-->
        <local:ui_window_Title2 Grid.Row="0" x:Name="_标题栏" ui_IsMaxButton="False"  ui_IsMinButton="False" Grid.ColumnSpan="2" />

        <!--工作区-->
        <Grid Grid.Row="1" Grid.ColumnSpan="2">

            <Grid.ColumnDefinitions >
                <ColumnDefinition  Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!--用户信息-->
            <ListView Grid.Column="0" x:Name="_listView" Margin="5" 
                      ItemsSource="{Binding LoginInfo_}" SelectedIndex="{Binding Index_ListView选中行}" />


            <!--按钮操作-->
            <Border Grid.Column ="1" x:Name="_按钮栏"  BorderBrush="Silver" BorderThickness="2,0,0,0" Grid.RowSpan="2">
                <StackPanel Orientation="Vertical"  Margin="5">
                    <local:ui_ButtonBorder x:Name="_添加" ui_Text="{Binding Languang.添加}" Margin="3" Height="35" 
                                           Command="{Binding 添加Command}" />
                    <local:ui_ButtonBorder x:Name="_修改" ui_Text="{Binding Languang.修改}" Margin="3" Height="35"
                                           Command="{Binding 修改Command}"/>
                    <local:ui_ButtonBorder x:Name="_删除" ui_Text="{Binding Languang.删除}" Margin="3" Height="35"
                                           Command="{Binding 删除Command}"/>
                    <local:ui_ButtonBorder x:Name="_保存" ui_Text="{Binding Languang.保存}" Margin="3" Height="35"
                         Command="{Binding 保存Command}"/>

                </StackPanel>
            </Border>


        </Grid>





    </Grid>
</Window>
