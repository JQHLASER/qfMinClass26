<UserControl x:Class="qfWPFmain.ui_Log"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:qfWPFmain"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="600" Background="Transparent" Loaded="UserControl_Loaded" SizeChanged="UserControl_SizeChanged">


    <Border Name="Border"
            Background="White"  
            BorderBrush="Silver"
            BorderThickness="1"
            CornerRadius="5"
            Padding="0"
            Margin="0"
            >

        <ListView Name="ListView_" ItemsSource="{Binding  LogItems }"    local:ListVieW附加属性.ui_光标跳转到最后一行  ="true"
                  FontFamily="微软雅黑"
                  Background="Transparent"   
                  FontSize="14"
                  Foreground="Black" 
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                  BorderBrush="Transparent"                  
                  BorderThickness="0" 
                  PreviewMouseDoubleClick="ListView__PreviewMouseDoubleClick"
                  Margin=" 0"
                  Padding=" 0"  
                  SelectedIndex="{Binding SelectedIndex}"
                  
                  >

            <!-- 定义行样式 -->


            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">

                    <!--绑定文本颜色-->
                    <Setter Property="Foreground" Value="{Binding TextColor}"/>

                </Style>
            </ListView.ItemContainerStyle>


            <!--<ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <GridViewRowPresenter>
                                    -->
            <!--为所有单元格文本设置不换行-->
            <!--
                                    <GridViewRowPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding TextColor}"/>
                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                            <Setter Property="Margin" Value="20,20,20,20"/>
                                        </Style>
                                    </GridViewRowPresenter.Resources>
                                </GridViewRowPresenter>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>-->





            <!-- 定义列 -->
            <ListView.View>

                <GridView>

                    <!-- 设置列标题的样式为隐藏 -->
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <!-- 将标题容器的可见性设为Collapsed -->
                            <Setter Property="Visibility" Value="Collapsed"/>

                        </Style>
                    </GridView.ColumnHeaderContainerStyle>

                    <GridViewColumn x:Name="时间" Header="时间" 
                                    Width="110"  
                                    DisplayMemberBinding="{Binding Dates}"/>
                    <GridViewColumn x:Name="状态" Header="状态" 
                                    Width="75" 
                                    DisplayMemberBinding="{Binding  States}"/>
                    <GridViewColumn x:Name="内容" Header="日志内容" Width="{Binding   Size内容栏}" 
                                     DisplayMemberBinding="{Binding  LogvalueShow}"/>

                </GridView>
            </ListView.View>

        </ListView>
    </Border>
</UserControl>
