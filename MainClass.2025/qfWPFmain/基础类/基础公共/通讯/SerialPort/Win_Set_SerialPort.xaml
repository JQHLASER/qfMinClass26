<Window x:Class="qfWPFmain.Win_Set_SerialPort"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:qfWPFmain"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Win_Set_SerialPort" Height="400" Width="600" WindowStyle="None"  ResizeMode="NoResize"  BorderThickness="1" BorderBrush="Silver" >

    <Window.Resources>

        <ControlTemplate x:Key="标签" TargetType="Label">
            <Label FontSize=" 15" FontFamily=" 微软雅黑" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" 
                   HorizontalContentAlignment="Right" Content="{TemplateBinding Content}"
                   Width="150" Height="30" Margin="0,0,10,0"/>
        </ControlTemplate>

        <FontFamily  x:Key="字体" >微软雅黑</FontFamily>
        <System:Double x:Key="字体大小">15</System:Double>
        <System:Double x:Key="Combobox_width">150</System:Double>
        <System:Double x:Key="Combobox_height">30</System:Double>
    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height=" *"/>
            <RowDefinition Height=" 80"/>
        </Grid.RowDefinitions>

        <!--标题栏-->
        <local:ui_window_Title x:Name="_标题栏" ui_isBox="False"    BorderThickness="0,0,0,1.5" BorderBrush="Silver"  />


        <!--参数-->
        <StackPanel Grid.Row="1" Margin="0,30,0,0">

            <!--串口名称-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Label x:Name="_串口名称_Label" Template="{StaticResource 标签}" Content="串口名称"/>
                <ComboBox x:Name="_串口名称_Combobox" 
                          FontFamily="{StaticResource 字体 }"  Width="{StaticResource Combobox_width }" Height="{StaticResource Combobox_height }"
                          FontSize="{StaticResource 字体大小 }"
                          VerticalAlignment="Stretch" VerticalContentAlignment="Center" 
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
            </StackPanel>

            <!--波特率-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"  Margin="0,10,0,0">
                <Label x:Name="_波特率_Label" Template="{StaticResource 标签}" Content="波特率"/>
                <ComboBox x:Name="_波特率_Combobox" 
                            FontFamily="{StaticResource 字体 }" Width="{StaticResource Combobox_width }" Height="{StaticResource Combobox_height }"
                            FontSize="{StaticResource 字体大小 }"
                            VerticalAlignment="Stretch" VerticalContentAlignment="Center" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
            </StackPanel>

            <!--数据位-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"  Margin="0,10,0,0">
                <Label x:Name="_数据位_Label" Template="{StaticResource 标签 }" Content="数据位"/>
                <ComboBox x:Name="_数据位_Combobox" 
                            FontFamily="{StaticResource 字体 }" Width="{StaticResource Combobox_width }" Height="{StaticResource Combobox_height }"
                            FontSize="{StaticResource 字体大小 }"
                            VerticalAlignment="Stretch" VerticalContentAlignment="Center" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
            </StackPanel>

            <!--停止位-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"  Margin="0,10,0,0">
                <Label x:Name="_停止位_Label" Template="{StaticResource 标签}" Content="停止位"/>
                <ComboBox x:Name="_停止位_Combobox" 
                            FontFamily="{StaticResource 字体 }" Width="{StaticResource Combobox_width }" Height="{StaticResource Combobox_height }"
                            FontSize="{StaticResource 字体大小 }"
                            VerticalAlignment="Stretch" VerticalContentAlignment="Center" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
            </StackPanel>

            <!--校验位-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"  Margin="0,10,0,0">
                <Label x:Name="_校验位_Label" Template="{StaticResource 标签}" Content="校验位"/>
                <ComboBox x:Name="_校验位_Combobox" 
                             FontFamily="{StaticResource 字体 }" Width="{StaticResource Combobox_width }" Height="{StaticResource Combobox_height }"
                            FontSize="{StaticResource 字体大小 }"
                            VerticalAlignment="Stretch" VerticalContentAlignment="Center" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
            </StackPanel>






        </StackPanel>



        <!--按钮-->
        <Border Grid.Row="2"  BorderThickness="0,1.5,0,0" BorderBrush="Silver">

            <Grid Margin="0,15,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width=" 0.25*"/>
                    <ColumnDefinition Width=" 0.4*"/>
                    <ColumnDefinition Width=" 0.2*"/>
                    <ColumnDefinition Width=" 0.4*"/>
                    <ColumnDefinition Width=" 0.25*"/>
                </Grid.ColumnDefinitions>

                <local:ui_ButtonBorder x:Name="_Button_Yes" Grid.Column ="1" ui_Text="Yes" 
                                       PreviewMouseLeftButtonUp="_Button_Yes_PreviewMouseLeftButtonUp"
                                        />

                <local:ui_ButtonBorder x:Name="_Button_No" Grid.Column ="3" ui_Text="No" 
                                       PreviewMouseLeftButtonUp="_Button_No_PreviewMouseLeftButtonUp"
                         />


            </Grid>




        </Border>


    </Grid>
</Window>
