<Window x:Class="qfWPFmain.Win_Set_Socket"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:qfWPFmain" 
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="" Height="300" Width="500" WindowStyle="None" ResizeMode="NoResize"  BorderThickness="1" BorderBrush="Silver">

    <Window.Resources>
        <ControlTemplate x:Key="标签" TargetType="Label">
            <Label Width="60" Height=" 30" VerticalAlignment="Stretch" VerticalContentAlignment="Center"  HorizontalAlignment="Stretch" 
                   HorizontalContentAlignment="Right" Margin="0,0,10,0" FontSize="15" FontFamily=" 微软雅黑"
                   Content="{TemplateBinding Content}" />
        </ControlTemplate>

        <System:Double  x:Key="_输入区宽度">200</System:Double>
        <System:Double  x:Key="_输入区高度">30</System:Double>

    </Window.Resources>




    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height=" 40"/>
            <RowDefinition Height=" *"/>
            <RowDefinition Height=" 80"/>
        </Grid.RowDefinitions>

        <!--标题栏-->
        <local:ui_window_Title x:Name="_标题栏" Grid.Row=" 0"  ui_is任务栏中显示Icon="false" ui_IsMaxButton="False"  ui_IsMinButton="False"
                               ui_IsCloseButton="True"  ui_Text="TCP/IP"
                               BorderBrush="Silver" BorderThickness="0,0,0,1.5"/>


        <!--输入区-->
        <Grid  Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height=" 50"/>
                <RowDefinition Height=" 50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>




            <!--IP-->
            <StackPanel Grid.Row=" 1" x:Name="_IP"
                            Orientation="Horizontal" HorizontalAlignment="Center">
                <Label Template="{StaticResource 标签}" Content="IP"/>
                <local:ui_TextBox  x:Name="_textBox_Ip"  Width="{StaticResource _输入区宽度}"  Height="{StaticResource _输入区高度 }"  
                                   ui_CornerRadius="0" ui_输入值类型="String"/>
            </StackPanel>


            <!--Port-->
            <StackPanel Grid.Row=" 2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Label Template="{StaticResource 标签}" Content="Port"/>
                <local:ui_TextBox x:Name="_textBox_Port"  Width="{StaticResource _输入区宽度}"  Height="{StaticResource _输入区高度 }"
                                  ui_CornerRadius="0"  ui_输入值类型="Int" ui_最小值="0"/>
            </StackPanel>




        </Grid>



        <!--按钮栏-->
        <Border  Grid.Row="2" Background="White" BorderBrush="Silver" BorderThickness="0,1.5,0,0" Padding="0,15,0,15">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width=" 0.2*"/>
                    <ColumnDefinition Width=" 0.25*"/>
                    <ColumnDefinition Width=" 0.15*"/>
                    <ColumnDefinition Width=" 0.25*"/>
                    <ColumnDefinition Width=" 0.2*"/>
                </Grid.ColumnDefinitions>

                <!--Yes-->
                <local:ui_ButtonBorder x:Name="_Button_Yes"  Grid.Column="1" ui_Text="Yes" PreviewMouseLeftButtonUp="_Button_Yes_PreviewMouseLeftButtonUp"/>

                <!--No-->
                <local:ui_ButtonBorder x:Name="_Button_No" Grid.Column="3" ui_Text="No" 
                                       PreviewMouseLeftButtonUp="_Button_No_PreviewMouseLeftButtonUp" />

            </Grid>

        </Border>



    </Grid>

</Window>
