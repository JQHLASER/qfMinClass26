<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:qfWPFmain">

    <!--uio_Button-->

    <Style TargetType="{x:Type local:uio_Button}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:uio_Button}">
                    <Border Background="Transparent"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding CornerRadius}"
                            >

                        <Button  
                            >

                            <Button.Clip >
                                <RectangleGeometry RadiusX="50" RadiusY="50"   >
                                    <RectangleGeometry.Rect>
                                        <Rect X="0" Y="0" Width="{TemplateBinding Width }" Height="{TemplateBinding Height}"  />
                                    </RectangleGeometry.Rect>
                                </RectangleGeometry>
                            </Button.Clip>


                        </Button>


                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


  


</ResourceDictionary>
